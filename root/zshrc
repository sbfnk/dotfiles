# Nudge if ~/.claude/projects backup to pCloud is overdue (>7 days)
() {
  local dir="$HOME/pCloud Drive/Backups/claude-projects"
  [ -d "$dir" ] || return
  local -a files
  files=( "$dir"/claude-projects-*.tar.gz(N.om) )
  if (( ${#files} == 0 )); then
    print -P "%F{yellow}⚠ no claude-projects backup yet — run: backup-claude-projects%f"
    return
  fi
  local mtime
  mtime=$(stat -f %m "${files[1]}" 2>/dev/null) || return
  [[ -n "$mtime" ]] || return
  local age_days=$(( ( $(date +%s) - mtime ) / 86400 ))
  (( age_days > 7 )) && print -P "%F{yellow}⚠ claude-projects backup is ${age_days}d old — run: backup-claude-projects%f"
}

