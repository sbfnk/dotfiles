# Custom precmd hook replaces zim termtitle for tmux windows
_tmux_title_precmd() {
  local name
  if name=$(git rev-parse --show-toplevel 2>/dev/null); then
    name=${name:t}  # basename
  else
    name=${(%):-%1~}  # current dir
  fi
  if [[ -n "$TMUX" ]]; then
    # Only rename if this pane is the active one *of its own window* (avoids
    # panes racing over the name) and target that window explicitly, so a shell
    # in a background window still renames its own tab rather than the one on
    # screen.
    if [[ $(tmux display-message -p -t "$TMUX_PANE" '#{pane_active}' 2>/dev/null) == 1 ]]; then
      tmux rename-window -t "$TMUX_PANE" "$name" 2>/dev/null
    fi
  else
    print -Pn "\E]0;${name}\a"
  fi
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd _tmux_title_precmd

