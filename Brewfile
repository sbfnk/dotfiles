# Essential packages — installed in both --minimal and --full profiles.
# Declarative replacement for the inline `brew install` list in install.sh.
# Apply with: brew bundle --file=Brewfile  (idempotent — skips what's present)
# (homebrew/autoupdate is tapped imperatively in install.sh — it needs
#  `brew trust` and is paired with `brew autoupdate start`.)

brew "git"
brew "wget"
brew "tmux"
brew "ripgrep"
brew "gh"
brew "jq"
brew "node"
brew "neovim"
brew "btop"
brew "python"
brew "zoxide"
brew "fzf"
brew "gitleaks"
